<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>TheraEpiFlow Report — {{ project_meta.project_name }}</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&family=IBM+Plex+Sans:wght@300;400;500;600&display=swap');
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#0a0e14; --surface:#111620; --surface2:#171e2b;
  --border:#1e2a3a; --border2:#2a3a50;
  --accent:#00d4ff; --green:#00e676; --amber:#ffb300; --red:#ff5252;
  --purple:#b388ff; --pink:#ff80ab;
  --text:#e8f0f8; --text2:#7a9ab8; --text3:#3d5a73;
  --mono:'IBM Plex Mono',monospace; --sans:'IBM Plex Sans',sans-serif;
}
body{background:var(--bg);color:var(--text);font-family:var(--sans);font-size:13px;line-height:1.5;overflow:hidden;height:100vh}
.app{display:flex;flex-direction:column;height:100vh}

/* ── Header ──────────────────────────────────────────────── */
.header{padding:9px 16px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;background:var(--surface);flex-shrink:0;gap:8px;flex-wrap:wrap}
.logo{font-family:var(--mono);font-size:12px;font-weight:600;color:var(--accent);letter-spacing:1.5px}
.logo span{color:var(--text3);font-weight:400}
.sublogo{font-size:9px;color:var(--text3);font-family:var(--mono);margin-top:1px}
.hmetrics{display:flex;gap:12px;align-items:center;flex-wrap:wrap}
.hm{text-align:center;min-width:48px}
.hm-val{font-family:var(--mono);font-size:14px;font-weight:600;line-height:1.1}
.hm-lab{font-size:9px;color:var(--text3);text-transform:uppercase;letter-spacing:.4px;margin-top:2px}
.ring-wrap{position:relative;width:40px;height:40px;flex-shrink:0}
.ring-wrap svg{transform:rotate(-90deg)}
.ring-bg{fill:none;stroke:var(--border2);stroke-width:4}
.ring-fg{fill:none;stroke-width:4;stroke-linecap:round;transition:stroke-dashoffset .5s cubic-bezier(.4,0,.2,1),stroke .3s}
.ring-txt{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;font-family:var(--mono);font-size:9px;font-weight:600}

/* ── Body 2-pane ──────────────────────────────────────────── */
.body{display:flex;flex:1;overflow:hidden}
.left{width:54%;border-right:1px solid var(--border);display:flex;flex-direction:column;overflow:hidden}
.right{width:46%;display:flex;flex-direction:column;overflow:hidden}

/* ── Toolbar (button filters) ─────────────────────────────── */
.toolbar{padding:6px 10px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:5px;flex-wrap:wrap;flex-shrink:0;background:var(--surface)}
.tlab{font-family:var(--mono);font-size:9px;color:var(--text3);text-transform:uppercase;letter-spacing:.6px;white-space:nowrap}
.fb{font-family:var(--mono);font-size:9px;padding:3px 7px;border:1px solid var(--border2);border-radius:3px;background:transparent;color:var(--text2);cursor:pointer;transition:all .12s;white-space:nowrap}
.fb:hover{background:var(--surface2)}
.fb.on{background:var(--accent);color:var(--bg);border-color:var(--accent);font-weight:600}
.vsep{width:1px;height:14px;background:var(--border2);flex-shrink:0}
.srch{font-family:var(--mono);font-size:10px;padding:3px 8px;background:var(--surface2);border:1px solid var(--border2);border-radius:3px;color:var(--text);width:140px;outline:none;margin-left:auto}
.srch::placeholder{color:var(--text3)}
.srch:focus{border-color:var(--accent)}

/* ── Table ────────────────────────────────────────────────── */
.tw{flex:1;overflow-y:auto}
.tw::-webkit-scrollbar{width:3px}
.tw::-webkit-scrollbar-thumb{background:var(--border2);border-radius:2px}
table.ep{width:100%;border-collapse:collapse}
table.ep thead th{position:sticky;top:0;background:var(--surface2);font-family:var(--mono);font-size:9px;font-weight:600;color:var(--text3);text-transform:uppercase;letter-spacing:.7px;padding:6px 6px;text-align:left;border-bottom:1px solid var(--border);white-space:nowrap;cursor:pointer;user-select:none}
table.ep thead th:hover{color:var(--text2)}
table.ep thead th:first-child{padding-left:10px}
table.ep tbody tr{border-bottom:1px solid var(--border);cursor:pointer;transition:background .08s}
table.ep tbody tr:hover{background:var(--surface2)}
table.ep tbody tr.sel{background:rgba(0,212,255,.08);border-left:2px solid var(--accent)}
table.ep tbody tr.sel td:first-child{padding-left:8px}
table.ep td{padding:6px 6px;vertical-align:middle}
table.ep td:first-child{padding-left:10px}

.seq-t{font-family:var(--mono);font-size:11px;font-weight:500;letter-spacing:.7px}
.pb{display:inline-block;font-family:var(--mono);font-size:9px;font-weight:600;padding:2px 6px;border-radius:3px;text-align:center;min-width:48px}
.pb.optimal,.pb.perfect{background:rgba(0,230,118,.18);color:#00e676}
.pb.good,.pb.high{background:rgba(146,208,80,.20);color:#92d050}
.pb.borderline,.pb.moderate{background:rgba(255,179,0,.20);color:#ffb300}
.pb.non_binder,.pb.low{background:rgba(255,82,82,.20);color:#ff5252}
.pb.unknown,.pb.conservation_unknown{background:rgba(122,154,184,.15);color:#7a9ab8}
.mbw{display:flex;align-items:center;gap:4px}
.mb{height:3px;background:var(--border2);border-radius:2px;width:36px;overflow:hidden}
.mf{height:100%;border-radius:2px;background:var(--accent)}
.mv{font-family:var(--mono);font-size:9px;color:var(--text2);min-width:24px;text-align:right}
.cobcell{display:inline-block;font-family:var(--mono);font-size:10px;font-weight:600;padding:2px 6px;border-radius:3px;min-width:54px;text-align:right}
.cobcell.high{background:rgba(0,230,118,.18);color:#00e676}
.cobcell.mid{background:rgba(255,179,0,.20);color:#ffb300}
.cobcell.low{background:rgba(255,82,82,.20);color:#ff5252}
.cobcell.none{background:var(--border2);color:var(--text3)}
.addbtn{width:20px;height:20px;border-radius:3px;border:1px solid var(--border2);background:transparent;color:var(--text2);cursor:pointer;font-size:12px;display:inline-flex;align-items:center;justify-content:center;transition:all .12s;line-height:1;font-family:var(--mono)}
.addbtn:hover{border-color:var(--accent);color:var(--accent);background:rgba(0,212,255,.06)}
.addbtn.on{background:var(--accent);color:var(--bg);border-color:var(--accent);font-size:11px}

/* ── Pager ────────────────────────────────────────────────── */
.pager{display:flex;align-items:center;gap:6px;padding:5px 10px;border-top:1px solid var(--border);flex-shrink:0;background:var(--surface)}
.pgbtn{font-family:var(--mono);font-size:9px;padding:3px 8px;border:1px solid var(--border2);border-radius:3px;background:transparent;color:var(--text2);cursor:pointer;transition:all .12s}
.pgbtn:hover:not(:disabled){background:var(--surface2);color:var(--text)}
.pgbtn:disabled{opacity:.3;cursor:default}
.pginfo{font-family:var(--mono);font-size:9px;color:var(--text3);margin:0 4px}

/* ── Right pane sections ──────────────────────────────────── */
.sec{padding:9px 12px;border-bottom:1px solid var(--border);flex-shrink:0}
.stitle{font-family:var(--mono);font-size:9px;color:var(--text3);text-transform:uppercase;letter-spacing:.9px;margin-bottom:6px;display:flex;justify-content:space-between;align-items:center}
.stitle a{color:var(--text3);cursor:pointer;font-size:9px;transition:color .12s}
.stitle a:hover{color:var(--red)}

/* Construct controls */
.ctrl-row{display:flex;gap:8px;align-items:center;flex-wrap:wrap;margin-bottom:7px}
.cg{display:flex;align-items:center;gap:4px}
.cl{font-family:var(--mono);font-size:9px;color:var(--text3);text-transform:uppercase;white-space:nowrap}
.ci{font-family:var(--mono);font-size:10px;padding:3px 6px;background:var(--surface2);border:1px solid var(--border2);border-radius:3px;color:var(--text);width:80px;outline:none}
.ci:focus{border-color:var(--accent)}
.htg{display:flex;gap:3px}
.htb{font-family:var(--mono);font-size:9px;padding:3px 7px;border:1px solid var(--border2);border-radius:3px;background:transparent;color:var(--text2);cursor:pointer;transition:all .12s}
.htb.on{background:rgba(255,179,0,.20);color:var(--amber);border-color:var(--amber)}
.seqbuild{display:flex;align-items:flex-start;flex-wrap:wrap;gap:2px;padding:6px;background:var(--surface2);border:1px solid var(--border);border-radius:4px;min-height:34px;margin-bottom:6px}
.hischip{font-family:var(--mono);font-size:9px;font-weight:600;padding:2px 5px;border-radius:3px;background:rgba(255,179,0,.20);color:var(--amber);border:1px solid rgba(255,179,0,.40)}
.epichip{font-family:var(--mono);font-size:9px;font-weight:600;padding:2px 5px;border-radius:3px;cursor:pointer;transition:opacity .12s;white-space:nowrap;background:var(--accent);color:var(--bg)}
.epichip:hover{opacity:.6}
.lchip{font-family:var(--mono);font-size:8px;color:var(--text3);padding:0 1px;line-height:2.2}
.emptyseq{font-family:var(--mono);font-size:10px;color:var(--text3);width:100%;text-align:center}
.sztrack{height:4px;background:var(--border2);border-radius:2px;overflow:hidden;margin-bottom:4px}
.szfill{height:100%;border-radius:2px;background:var(--accent);transition:width .45s cubic-bezier(.4,0,.2,1),background .3s}
.szrow{display:flex;justify-content:space-between;align-items:center;font-family:var(--mono)}
.szval{font-size:10px;font-weight:600;color:var(--text2)}
.szsub{font-size:9px;color:var(--text3)}
.consrow{display:flex;justify-content:space-between;font-family:var(--mono);font-size:9px;color:var(--text3);margin-top:4px;padding-top:4px;border-top:1px solid var(--border)}
.consrow .v{color:var(--text2);font-weight:600}

/* Coverage matrix (selected × populations) */
table.cm{width:100%;border-collapse:separate;border-spacing:2px;margin-top:4px}
table.cm th.cmh{font-family:var(--mono);font-size:9px;color:var(--text3);text-transform:uppercase;padding:2px 4px;text-align:center}
table.cm td.cmrow{font-family:var(--mono);font-size:9px;color:var(--text2);padding:2px 6px 2px 2px;white-space:nowrap;max-width:140px;overflow:hidden;text-overflow:ellipsis;text-align:left}
table.cm td.cmcell{font-family:var(--mono);font-size:9px;text-align:center;padding:4px 6px;border-radius:3px;min-width:54px}
table.cm td.cmcell.high{background:rgba(0,176,80,.55);color:#fff}
table.cm td.cmcell.mid{background:rgba(255,179,0,.30);color:var(--amber)}
table.cm td.cmcell.low{background:rgba(255,82,82,.30);color:var(--red)}
table.cm td.cmcell.none{background:var(--border2);color:var(--text3)}
table.cm tr.cmsum td{border-top:1px solid var(--border2);padding-top:5px;font-weight:700}

/* Distribution heatmap (organism × protein) */
table.mx{border-collapse:separate;border-spacing:3px;width:100%}
table.mx th.mxh{font-family:var(--mono);font-size:9px;font-weight:600;text-transform:uppercase;letter-spacing:.5px;padding:2px 4px;text-align:center;color:var(--text3)}
table.mx td.mxrow{font-family:var(--mono);font-size:9px;font-weight:600;padding:0 6px 0 2px;white-space:nowrap;vertical-align:middle;color:var(--text2);text-align:right}
.mxcell{width:100%;height:28px;border-radius:4px;display:flex;align-items:center;justify-content:center}
.mxcell.c0{background:rgba(255,82,82,.10);border:1px solid rgba(255,82,82,.25)}
.mxcell.c1{background:rgba(255,179,0,.14);border:1px solid rgba(255,179,0,.28)}
.mxcell.c2{background:rgba(0,230,118,.14);border:1px solid rgba(0,230,118,.28)}
.mxcell.c3{background:rgba(0,230,118,.22);border:1px solid rgba(0,230,118,.40)}
.mxn{font-family:var(--mono);font-size:12px;font-weight:600}
.mxcell.c0 .mxn{color:#ff5252}
.mxcell.c1 .mxn{color:#ffb300}
.mxcell.c2 .mxn,.mxcell.c3 .mxn{color:#00e676}

/* Selected list */
.pscroll{flex:1;overflow-y:auto;padding:9px 12px;min-height:60px}
.pscroll::-webkit-scrollbar{width:3px}
.pscroll::-webkit-scrollbar-thumb{background:var(--border2);border-radius:2px}
.selitem{display:flex;align-items:center;gap:5px;padding:5px 7px;background:var(--surface2);border:1px solid var(--border);border-radius:3px;margin-bottom:3px}
.sidot{width:6px;height:6px;border-radius:2px;flex-shrink:0;background:var(--accent)}
.siseq{font-family:var(--mono);font-size:10px;font-weight:500;color:var(--text);flex:1;letter-spacing:.4px}
.sitag{font-family:var(--mono);font-size:8px;padding:1px 4px;border-radius:2px;background:var(--surface);color:var(--text3)}
.rem{background:transparent;border:none;color:var(--text3);cursor:pointer;font-size:13px;padding:0 2px;line-height:1;transition:color .12s}
.rem:hover{color:var(--red)}
.empty{text-align:center;padding:18px 10px;color:var(--text3);font-family:var(--mono);font-size:10px;line-height:1.8}

/* Export row */
.exprow{padding:7px 12px;border-top:1px solid var(--border);display:flex;gap:5px;flex-shrink:0;background:var(--surface)}
.expbtn{flex:1;padding:7px;border-radius:3px;background:transparent;border:1px solid var(--border2);color:var(--text2);font-family:var(--mono);font-size:10px;cursor:pointer;transition:all .12s;text-align:center}
.expbtn:hover{border-color:var(--accent);color:var(--accent);background:rgba(0,212,255,.05)}
.expbtn:disabled{opacity:.4;cursor:not-allowed}
</style>
</head>
<body>
<div class="app">

  <!-- ─── HEADER ─────────────────────────────────────────── -->
  <div class="header">
    <div>
      <div class="logo">TheraEpiFlow <span>/ {{ project_meta.project_name }} · MHC-I CTL</span></div>
      <div class="sublogo">
        {{ project_meta.n_organisms }} organism{{ 's' if project_meta.n_organisms != 1 else '' }} ·
        {{ project_meta.n_proteins }} protein{{ 's' if project_meta.n_proteins != 1 else '' }} ·
        {{ project_meta.n_peptides_total }} ★ peptides ·
        {{ project_meta.populations|length }} population{{ 's' if project_meta.populations|length != 1 else '' }}
        · generated {{ project_meta.generated_at }}
      </div>
    </div>
    <div class="hmetrics">
      <div class="hm"><div class="hm-val" id="h-count" style="color:var(--accent)">0</div><div class="hm-lab">selected</div></div>
      <div class="hm"><div class="hm-val" id="h-cov"   style="color:var(--green)">—</div><div class="hm-lab">mean cov.</div></div>
      <div class="hm"><div class="hm-val" id="h-aa"    style="color:var(--amber)">0</div><div class="hm-lab">aa</div></div>
      <div class="hm"><div class="hm-val" id="h-nt"    style="color:var(--purple)">0</div><div class="hm-lab">nt</div></div>
      <div class="hm"><div class="hm-val" id="h-bp"    style="color:var(--pink)">0bp</div><div class="hm-lab">bp</div></div>
      <div class="hm"><div class="hm-val" id="h-mw"    style="color:var(--text2)">0</div><div class="hm-lab">MW Da</div></div>
      <div style="display:flex;align-items:center;gap:6px">
        <div class="ring-wrap">
          <svg width="40" height="40" viewBox="0 0 40 40">
            <circle class="ring-bg" cx="20" cy="20" r="16"/>
            <circle class="ring-fg" id="ring-fg" cx="20" cy="20" r="16" stroke="var(--green)" stroke-dasharray="100.5" stroke-dashoffset="100.5"/>
          </svg>
          <div class="ring-txt" id="ring-txt" style="color:var(--green)">0/{{ project_meta.n_organisms * project_meta.n_proteins }}</div>
        </div>
        <div>
          <div style="font-family:var(--mono);font-size:9px;color:var(--text2);font-weight:600">coverage</div>
          <div style="font-family:var(--mono);font-size:8px;color:var(--text3)">org × prot</div>
        </div>
      </div>
    </div>
  </div>

  <!-- ─── BODY (2 panes) ─────────────────────────────────── -->
  <div class="body">

    <!-- LEFT — toolbar + table + pager -->
    <div class="left">
      <div class="toolbar">
        <span class="tlab">Prot.</span>
        <button class="fb on" data-filter="protein" data-value="">All</button>
        {% for protein in project_meta.proteins %}
        <button class="fb" data-filter="protein" data-value="{{ protein }}">{{ protein }}</button>
        {% endfor %}
        <div class="vsep"></div>
        <span class="tlab">Org.</span>
        <button class="fb on" data-filter="organism" data-value="">All</button>
        {% for organism in project_meta.organisms %}
        <button class="fb" data-filter="organism" data-value="{{ organism }}">{{ organism }}</button>
        {% endfor %}
        <div class="vsep"></div>
        <span class="tlab">Flag</span>
        <button class="fb on" data-filter="flag" data-value="">All</button>
        <button class="fb" data-filter="flag" data-value="strong">★ &lt;0.5</button>
        <button class="fb" data-filter="flag" data-value="conserved">conserved</button>
        <input class="srch" id="srch" placeholder="search seq...">
      </div>
      <div class="tw">
        <table class="ep">
          <thead><tr id="ep-thead"></tr></thead>
          <tbody id="ep-tbody"></tbody>
        </table>
      </div>
      <div class="pager">
        <button class="pgbtn" id="pg-prev">← prev</button>
        <span class="pginfo" id="pginfo">page 1</span>
        <button class="pgbtn" id="pg-next">next →</button>
        <span style="font-family:var(--mono);font-size:9px;color:var(--text3);margin-left:6px" id="pgcount"></span>
      </div>
    </div>

    <!-- RIGHT — construct + 2 heatmaps + selected + exports -->
    <div class="right">

      <!-- Construct -->
      <div class="sec">
        <div class="stitle"><span>Construct</span><a id="btn-clear">clear all</a></div>
        <div class="ctrl-row">
          <div class="cg">
            <span class="cl">Linker</span>
            <input class="ci" id="linker" value="GPGPG">
          </div>
          <div class="cg">
            <span class="cl">6×His</span>
            <div class="htg">
              <button class="htb" id="ht-N">N</button>
              <button class="htb on" id="ht-C">C</button>
              <button class="htb" id="ht-off">off</button>
            </div>
          </div>
        </div>
        <div class="seqbuild" id="seqbuild"><div class="emptyseq">no epitopes selected — click a row in the table to add</div></div>
        <div class="sztrack"><div class="szfill" id="szfill" style="width:0%"></div></div>
        <div class="szrow">
          <span class="szval" id="szval">0 aa</span>
          <span class="szsub" id="szbreak"></span>
        </div>
        <div class="consrow">
          <span>Mean conservation @100%</span>
          <span class="v" id="h-cons">—</span>
        </div>
      </div>

      <!-- Population coverage (selected × populations) -->
      <div class="sec">
        <div class="stitle">
          <span>Population coverage &nbsp;<span style="color:var(--text3);font-weight:400;text-transform:none;letter-spacing:0">selected × populations · diploid IEDB</span></span>
        </div>
        <div id="covmat"><div class="empty">select epitopes to see population coverage</div></div>
      </div>

      <!-- Distribution heatmap (org × prot) -->
      <div class="sec">
        <div class="stitle">
          <span>Distribution &nbsp;<span style="color:var(--text3);font-weight:400;text-transform:none;letter-spacing:0">organism × protein · epitope count</span></span>
        </div>
        <div id="distmap"></div>
      </div>

      <!-- Selected list -->
      <div class="pscroll">
        <div class="stitle">Selected epitopes <span id="sellist-count" style="color:var(--text2)"></span></div>
        <div id="sellist"><div class="empty">no epitopes selected<br>click a row in the table to add</div></div>
      </div>

      <!-- Export row -->
      <div class="exprow">
        <button class="expbtn" id="exp-tsv">↓ .tsv</button>
        <button class="expbtn" id="exp-fasta">↓ .fasta</button>
        <button class="expbtn" id="exp-matrix">↓ matrix</button>
      </div>

    </div>
  </div>
</div>

<!-- ─── Data inlined ─────────────────────────────────────── -->
<script>
window.EPITOPES     = {{ epitopes_json     | safe }};
window.PROJECT_META = {{ project_meta_json | safe }};
window.COVERAGE_DB  = {{ coverage_db_json  | safe }};
</script>

<!-- ─── Main app ─────────────────────────────────────────── -->
<script>
(function(){
  'use strict';

  const $  = (s) => document.querySelector(s);
  const $$ = (s) => document.querySelectorAll(s);

  const EPS  = window.EPITOPES;
  const META = window.PROJECT_META;
  const COV  = window.COVERAGE_DB;   // {pop: {locus: {allele: freq}}}

  // ── Monoisotopic amino-acid masses (Da) ──────────────────
  const AA_MASS = {
    A:71.03711, R:156.10111, N:114.04293, D:115.02694, C:103.00919,
    E:129.04259, Q:128.05858, G:57.02146,  H:137.05891, I:113.08406,
    L:113.08406, K:128.09496, M:131.04049, F:147.06841, P:97.05276,
    S:87.03203,  T:101.04768, W:186.07931, Y:163.06333, V:99.06841,
  };
  const WATER = 18.01056;
  function calcMW(seq){ let m = WATER; for(const c of seq){ m += AA_MASS[c] || 0; } return Math.round(m); }

  // ── State ────────────────────────────────────────────────
  const selected = new Set();
  const filters  = { protein:'', organism:'', flag:'', search:'' };
  let sortKey = 'best_pct';
  let sortDir = 'asc';
  let hisPos  = 'C';
  let page    = 1;
  const PAGE_SIZE = 50;

  // ── Coverage math — diploid per locus (mirrors population_coverage/core.py) ──
  function cumulativeCoverage(unionAlleles, population){
    const lociFreq = COV[population] || {};
    const locusSum = {};
    unionAlleles.forEach(allele => {
      const locus = allele.split('*')[0];
      const freq = (lociFreq[locus] || {})[allele];
      if (freq != null){
        locusSum[locus] = (locusSum[locus] || 0) + freq;
      }
    });
    if (Object.keys(locusSum).length === 0) return 0;
    let notCovered = 1;
    for (const locus in locusSum){
      const q = Math.min(locusSum[locus], 1.0);
      const p_locus = 1 - Math.pow(1 - q, 2);
      notCovered *= (1 - p_locus);
    }
    return (1 - notCovered) * 100;
  }

  function meanCoverageAcrossPops(unionAlleles){
    if (unionAlleles.size === 0 || META.populations.length === 0) return null;
    let sum = 0;
    for (const p of META.populations) sum += cumulativeCoverage(unionAlleles, p);
    return sum / META.populations.length;
  }

  // ── Helpers ──────────────────────────────────────────────
  const fmt = (v) => (v == null || v === '') ? '—' : v;
  function covBand(v){
    if (v == null) return 'none';
    if (v >= 75) return 'high';
    if (v >= 25) return 'mid';
    return 'low';
  }
  function consPct(s){
    if (!s) return -1;
    const m = String(s).match(/(\d+(?:\.\d+)?)/);
    return m ? parseFloat(m[1]) : -1;
  }

  // ── Cell renderers ───────────────────────────────────────
  function mpPill(v){
    if (v == null) return '<span class="pb unknown">—</span>';
    let cls;
    if      (v < 0.5)  cls = 'optimal';
    else if (v < 1.0)  cls = 'good';
    else if (v < 2.0)  cls = 'borderline';
    else               cls = 'non_binder';
    return `<span class="pb ${cls}">${v.toFixed(2)}</span>`;
  }
  function hlaCell(e){
    const max_hla = Math.max(15, ...EPS.map(x => x.n_hla || 0));
    const pct = Math.min(100, ((e.n_hla || 0) / max_hla) * 100);
    const tip = (e.hla_list || []).join(', ');
    return `<div class="mbw" title="${tip}">
      <div class="mb"><div class="mf" style="width:${pct}%"></div></div>
      <span class="mv">${e.n_hla}</span>
    </div>`;
  }
  function murinePill(e){
    const lbl = e.murine_label || 'unknown';
    const tip = `best %ile: ${fmt(e.murine_pct)} · ${e.murine_n || 0} alleles`;
    return `<span class="pb ${lbl}" title="${tip}">${lbl}</span>`;
  }
  function bestPctTooltip(e){
    const lines = [`Best %ile (consensus): ${fmt(e.best_pct)}`];
    const net = e.net_pct_per_allele    || [];
    const flu = e.flurry_pct_per_allele || [];
    if (net.length || flu.length){
      lines.push('', 'Per-allele percentiles (NetMHCpan EL · MHCFlurry):');
      (e.hla_list || []).forEach((a, i) => {
        const n = net[i] != null ? net[i].toFixed(2) : '—';
        const f = flu[i] != null ? flu[i].toFixed(2) : '—';
        lines.push(`  ${a}  net=${n}  flu=${f}`);
      });
    }
    return lines.join('\n');
  }
  function covCellHtml(v){
    if (v == null) return '<span class="cobcell none">—</span>';
    const cls = v >= 75 ? 'high' : v >= 25 ? 'mid' : 'low';
    return `<span class="cobcell ${cls}">${v.toFixed(1)}%</span>`;
  }

  // ── Primary population (first configured) drives the Cob.% column ─
  const PRIMARY_POP = META.populations[0] || null;

  // ── Columns ──────────────────────────────────────────────
  const COLS = [
    { k:'protein',  l:'Prot',    r:e => `<span style="font-family:var(--mono);font-size:10px">${e.protein}</span>` },
    { k:'organism', l:'Org.',    r:e => `<span style="font-family:var(--mono);font-size:10px">${e.organism}</span>` },
    { k:'peptide',  l:'Sequence',r:e => `<span class="seq-t">${e.peptide}</span>` },
    { k:'cov',      l:'Cob.%',   getNum:e => PRIMARY_POP ? e.coverage[PRIMARY_POP] : null,
      r:e => covCellHtml(PRIMARY_POP ? e.coverage[PRIMARY_POP] : null) },
    { k:'best_pct', l:'MP',      getNum:e => e.best_pct,
      r:e => `<span title="${bestPctTooltip(e).replace(/"/g,'&quot;')}">${mpPill(e.best_pct)}</span>` },
    { k:'n_hla',    l:'HLA',     getNum:e => e.n_hla, r:hlaCell },
    { k:'murine',   l:'MHC 🐭', r:murinePill },
    { k:'add',      l:'',        r:e => {
        const isSel = selected.has(e.id);
        return `<button class="addbtn ${isSel?'on':''}" data-add="${e.id}">${isSel?'✓':'+'}</button>`;
      }},
  ];

  // ── Filter / sort ────────────────────────────────────────
  function visibleEps(){
    let out = EPS.filter(e => {
      if (filters.protein  && e.protein  !== filters.protein)  return false;
      if (filters.organism && e.organism !== filters.organism) return false;
      if (filters.flag === 'strong'   && (e.best_pct == null || e.best_pct >= 0.5)) return false;
      if (filters.flag === 'conserved' && !['perfect','high'].includes(e.cons_label || '')) return false;
      if (filters.search && !e.peptide.toUpperCase().includes(filters.search.toUpperCase())) return false;
      return true;
    });
    const col = COLS.find(c => c.k === sortKey);
    out.sort((a, b) => {
      const va = col?.getNum ? col.getNum(a) : a[sortKey];
      const vb = col?.getNum ? col.getNum(b) : b[sortKey];
      if (va == null && vb == null) return 0;
      if (va == null) return 1;
      if (vb == null) return -1;
      if (typeof va === 'number' && typeof vb === 'number') return sortDir === 'asc' ? va - vb : vb - va;
      return sortDir === 'asc' ? String(va).localeCompare(String(vb)) : String(vb).localeCompare(String(va));
    });
    return out;
  }

  // ── Render head + body ───────────────────────────────────
  function renderHead(){
    $('#ep-thead').innerHTML = COLS.map(c => {
      const arrow = c.k === sortKey ? (sortDir === 'asc' ? '▲' : '▼') : '';
      return `<th data-k="${c.k}">${c.l} <span style="color:var(--text3);font-size:8px">${arrow}</span></th>`;
    }).join('');
    $$('#ep-thead th').forEach(th => th.addEventListener('click', () => {
      const k = th.dataset.k;
      if (k === 'add') return;
      if (sortKey === k) sortDir = sortDir === 'asc' ? 'desc' : 'asc';
      else { sortKey = k; sortDir = 'asc'; }
      renderHead(); renderTable();
    }));
  }

  function renderTable(){
    const rows = visibleEps();
    const total = rows.length;
    const totalPages = Math.max(1, Math.ceil(total / PAGE_SIZE));
    if (page > totalPages) page = totalPages;
    const start = (page - 1) * PAGE_SIZE;
    const slice = rows.slice(start, start + PAGE_SIZE);

    if (total === 0){
      $('#ep-tbody').innerHTML =
        `<tr><td colspan="${COLS.length}" style="text-align:center;color:var(--text3);padding:24px;font-family:var(--mono);font-size:10px">no epitopes match the filters</td></tr>`;
    } else {
      $('#ep-tbody').innerHTML = slice.map(e => {
        const tds = COLS.map(c => `<td>${c.r(e)}</td>`).join('');
        return `<tr data-id="${e.id}" class="${selected.has(e.id) ? 'sel' : ''}">${tds}</tr>`;
      }).join('');
    }

    $$('#ep-tbody tr[data-id]').forEach(tr => tr.addEventListener('click', () => {
      toggleSel(parseInt(tr.dataset.id, 10));
    }));
    $$('#ep-tbody button[data-add]').forEach(btn => btn.addEventListener('click', (ev) => {
      ev.stopPropagation();
      toggleSel(parseInt(btn.dataset.add, 10));
    }));

    $('#pginfo').textContent  = `page ${page}/${totalPages}`;
    $('#pgcount').textContent = `${total} of ${EPS.length} epitopes`;
    $('#pg-prev').disabled = page === 1;
    $('#pg-next').disabled = page === totalPages;
  }

  // ── Selection ────────────────────────────────────────────
  function toggleSel(id){
    if (selected.has(id)) selected.delete(id); else selected.add(id);
    renderTable(); refresh();
  }
  function clearAll(){
    selected.clear();
    renderTable(); refresh();
  }

  // ── Construct ────────────────────────────────────────────
  function setHis(pos){
    hisPos = pos;
    ['N','C','off'].forEach(p => $('#ht-'+p).classList.toggle('on', pos === p));
    refresh();
  }

  function buildConstruct(){
    const lk = ($('#linker').value || '').trim().toUpperCase();
    const sels = [...selected].map(id => EPS.find(e => e.id === id)).filter(Boolean);
    const chips = []; const parts = [];
    if (hisPos === 'N'){ chips.push({c:'his', t:'HHHHHH'}); parts.push('HHHHHH'); }
    sels.forEach((e, i) => {
      if (i > 0 && lk){ chips.push({c:'lk', t:lk}); parts.push(lk); }
      chips.push({c:'ep', t:e.peptide, e}); parts.push(e.peptide);
    });
    if (hisPos === 'C'){ chips.push({c:'his', t:'HHHHHH'}); parts.push('HHHHHH'); }
    return { sels, chips, sequence: parts.join('') };
  }

  // ── Refresh derived UI ───────────────────────────────────
  function refresh(){
    const b = buildConstruct();

    // Preview chips
    $('#seqbuild').innerHTML = b.chips.length === 0
      ? '<div class="emptyseq">no epitopes selected — click a row in the table to add</div>'
      : b.chips.map(c => {
          if (c.c === 'his') return `<span class="hischip">${c.t}</span>`;
          if (c.c === 'lk')  return `<span class="lchip">${c.t}</span>`;
          return `<span class="epichip" data-rmv="${c.e.id}">${c.t}</span>`;
        }).join('');
    $$('#seqbuild .epichip').forEach(chip => chip.addEventListener('click', () => {
      toggleSel(parseInt(chip.dataset.rmv, 10));
    }));

    // Size bar
    const maxLen = 200;
    $('#szval').textContent = `${b.sequence.length} aa`;
    $('#szsub').textContent = `${b.sequence.length * 3} nt`;
    const w = Math.min(100, (b.sequence.length / maxLen) * 100);
    $('#szfill').style.width = w + '%';

    // Mean conservation @100% (under construct, ex-modal stat)
    const meanCons = b.sels.length
      ? b.sels.map(e => consPct(e.cons_100)).filter(v => v >= 0).reduce((a, c) => a + c, 0) / b.sels.length
      : null;
    $('#h-cons').textContent = meanCons == null ? '—' : meanCons.toFixed(1) + '%';

    // Selected list
    if (b.sels.length === 0){
      $('#sellist').innerHTML = '<div class="empty">no epitopes selected<br>click a row in the table to add</div>';
      $('#sellist-count').textContent = '';
    } else {
      $('#sellist').innerHTML = b.sels.map(e => `
        <div class="selitem">
          <span class="sidot"></span>
          <span class="siseq">${e.peptide}</span>
          <span class="sitag">${e.organism} · ${e.protein}</span>
          <button class="rem" data-rmv="${e.id}" title="remove">×</button>
        </div>
      `).join('');
      $('#sellist-count').textContent = `(${b.sels.length})`;
      $$('#sellist .rem').forEach(btn => btn.addEventListener('click', () => {
        toggleSel(parseInt(btn.dataset.rmv, 10));
      }));
    }

    // Header metrics
    const unionAlleles = new Set();
    b.sels.forEach(e => (e.hla_list || []).forEach(a => unionAlleles.add(a)));
    const meanCov = meanCoverageAcrossPops(unionAlleles);

    $('#h-count').textContent = b.sels.length;
    $('#h-cov').textContent   = meanCov == null ? '—' : meanCov.toFixed(1) + '%';
    $('#h-aa').textContent    = b.sequence.length;
    $('#h-nt').textContent    = b.sequence.length * 3;
    $('#h-bp').textContent    = (b.sequence.length * 3) + 'bp';
    $('#h-mw').textContent    = b.sequence ? calcMW(b.sequence).toLocaleString() : '0';

    // Progress ring (organism × protein combos covered)
    const RING_CIRC = 2 * Math.PI * 16;
    const covMap = {};
    META.organisms.forEach(o => META.proteins.forEach(p => { covMap[o+'|'+p] = 0; }));
    b.sels.forEach(e => { covMap[e.organism+'|'+e.protein] = (covMap[e.organism+'|'+e.protein] || 0) + 1; });
    const total   = META.organisms.length * META.proteins.length;
    const covered = Object.values(covMap).filter(n => n > 0).length;
    const frac    = total > 0 ? covered / total : 0;
    const ring = $('#ring-fg');
    if (ring){
      ring.setAttribute('stroke-dasharray',  RING_CIRC.toFixed(2));
      ring.setAttribute('stroke-dashoffset', (RING_CIRC * (1 - frac)).toFixed(2));
      ring.setAttribute('stroke', frac >= 0.66 ? 'var(--green)' : frac >= 0.33 ? 'var(--amber)' : 'var(--accent)');
    }
    $('#ring-txt').textContent = `${covered}/${total}`;

    // Heatmap 1: selected × populations
    renderCovMatrix(b.sels, unionAlleles);
    // Heatmap 2: organism × protein distribution
    renderDistMap(covMap);
  }

  function renderCovMatrix(sels, unionAlleles){
    const slot = $('#covmat');
    if (sels.length === 0 || META.populations.length === 0){
      slot.innerHTML = '<div class="empty">select epitopes to see population coverage</div>';
      return;
    }
    const pops = META.populations;
    const head = `<tr><th class="cmh"></th>${pops.map(p => `<th class="cmh">${p}</th>`).join('')}</tr>`;
    const rows = sels.map(e => {
      const cells = pops.map(p => {
        const v = e.coverage[p];
        if (v == null) return '<td class="cmcell none">—</td>';
        return `<td class="cmcell ${covBand(v)}">${v.toFixed(1)}%</td>`;
      }).join('');
      return `<tr><td class="cmrow" title="${e.peptide}">${e.peptide}</td>${cells}</tr>`;
    }).join('');
    const cumCells = pops.map(p => {
      const c = cumulativeCoverage(unionAlleles, p);
      return `<td class="cmcell ${covBand(c)}">${c.toFixed(1)}%</td>`;
    }).join('');
    const cumRow = `<tr class="cmsum"><td class="cmrow">Cumulative</td>${cumCells}</tr>`;
    slot.innerHTML = `<table class="cm">${head}${rows}${cumRow}</table>`;
  }

  function renderDistMap(covMap){
    const head = `<tr><th class="mxh"></th>${META.proteins.map(p => `<th class="mxh">${p}</th>`).join('')}</tr>`;
    const rows = META.organisms.map(o => {
      const cells = META.proteins.map(p => {
        const n = covMap[o+'|'+p] || 0;
        const cls = n === 0 ? 'c0' : n === 1 ? 'c1' : n < 3 ? 'c2' : 'c3';
        return `<td><div class="mxcell ${cls}"><span class="mxn">${n}</span></div></td>`;
      }).join('');
      return `<tr><td class="mxrow">${o}</td>${cells}</tr>`;
    }).join('');
    $('#distmap').innerHTML = `<table class="mx">${head}${rows}</table>`;
  }

  // ── Downloads ────────────────────────────────────────────
  function dl(content, filename, mime){
    const a = document.createElement('a');
    a.href = URL.createObjectURL(new Blob([content], { type: mime }));
    a.download = filename;
    a.click();
    URL.revokeObjectURL(a.href);
  }

  function expTSV(){
    if (selected.size === 0){
      alert('No epitopes selected. Click + on rows to add them.');
      return;
    }
    const sels = [...selected].map(id => EPS.find(e => e.id === id)).filter(Boolean);
    const popCols = META.populations.map(p => `cov_${p}`);
    const header  = ['organism','protein','peptide','best_pct','n_hla','hla_bound',
                     ...popCols,'murine_label','murine_pct','cons_100','cons_thr','cons_label'].join('\t');
    const rows = sels.map(e => [
      e.organism, e.protein, e.peptide,
      e.best_pct ?? '',
      e.n_hla,
      (e.hla_list || []).join(';'),
      ...META.populations.map(p => e.coverage[p] ?? ''),
      e.murine_label ?? '',
      e.murine_pct ?? '',
      e.cons_100 ?? '',
      e.cons_thr ?? '',
      e.cons_label ?? '',
    ].join('\t'));
    dl([header, ...rows].join('\n') + '\n', `${META.project_name}_selected_epitopes.tsv`, 'text/tab-separated-values');
  }

  function expFASTA(){
    const b = buildConstruct();
    if (b.sequence.length === 0){
      alert('No epitopes selected.');
      return;
    }
    const lk = ($('#linker').value || '').trim().toUpperCase() || 'GPGPG';
    const header = `>${META.project_name}_construct n_epitopes=${b.sels.length} length=${b.sequence.length}aa linker=${lk} his=${hisPos}`;
    const wrapped = (b.sequence.match(/.{1,60}/g) || []).join('\n');
    dl(`${header}\n${wrapped}\n`, `${META.project_name}_construct.fasta`, 'text/plain');
  }

  function expMatrix(){
    const sels = [...selected].map(id => EPS.find(e => e.id === id)).filter(Boolean);
    const lines = [['organism', ...META.proteins].join(',')];
    META.organisms.forEach(o => {
      const cells = META.proteins.map(p =>
        String(sels.filter(e => e.organism === o && e.protein === p).length));
      lines.push([o, ...cells].join(','));
    });
    dl(lines.join('\n') + '\n', `${META.project_name}_distribution.csv`, 'text/csv');
  }

  // ── Wire-up ──────────────────────────────────────────────
  $$('.toolbar .fb').forEach(btn => btn.addEventListener('click', () => {
    const filter = btn.dataset.filter, value = btn.dataset.value;
    filters[filter] = value;
    $$(`.toolbar .fb[data-filter="${filter}"]`).forEach(b => b.classList.remove('on'));
    btn.classList.add('on');
    page = 1; renderTable();
  }));
  $('#srch').addEventListener('input', (ev) => {
    filters.search = ev.target.value.trim();
    page = 1; renderTable();
  });
  $('#pg-prev').addEventListener('click', () => { if (page > 1){ page--; renderTable(); } });
  $('#pg-next').addEventListener('click', () => { page++; renderTable(); });
  $('#linker').addEventListener('input', refresh);
  $('#ht-N').addEventListener('click',   () => setHis('N'));
  $('#ht-C').addEventListener('click',   () => setHis('C'));
  $('#ht-off').addEventListener('click', () => setHis('off'));
  $('#btn-clear').addEventListener('click', clearAll);
  $('#exp-tsv').addEventListener('click',    expTSV);
  $('#exp-fasta').addEventListener('click',  expFASTA);
  $('#exp-matrix').addEventListener('click', expMatrix);

  // ── Init ─────────────────────────────────────────────────
  renderHead();
  renderTable();
  refresh();
})();
</script>
</body>
</html>
